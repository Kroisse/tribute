core.module @test {
  clif.func {sym_name = @test_fn, type = core.func(core.i32)} {
      %0 = clif.symbol_addr {sym = @lifted_fn} : core.ptr
      %1 = arith.const {value = 0} : core.ptr
      %2 = adt.struct_new %0, %1 {type = adt.struct(core.ptr, core.ptr) {fields = [[@func_ptr, core.ptr], [@env, core.ptr]], name = @_closure}} : adt.struct(core.ptr, core.ptr) {fields = [[@func_ptr, core.ptr], [@env, core.ptr]], name = @_closure}
      %3 = adt.struct_get %2 {field = 0, type = adt.struct(core.ptr, core.ptr) {fields = [[@func_ptr, core.ptr], [@env, core.ptr]], name = @_closure}} : core.ptr
      %4 = adt.struct_get %2 {field = 1, type = adt.struct(core.ptr, core.ptr) {fields = [[@func_ptr, core.ptr], [@env, core.ptr]], name = @_closure}} : core.ptr
      %5 = clif.call_indirect %3, %4 {sig = core.func(core.i32, core.ptr)} : core.i32
      clif.return %5
  }
}
