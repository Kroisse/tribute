core.module @test {
  func.func @invert(%0: core.i1) -> core.i1 {
      %1 = arith.const {value = true} : core.i1
      %2 = arith.cmp_eq %0, %1 : core.i1
      %3 = scf.if %2 : core.i1 {
          %4 = arith.const {value = false} : core.i1
          scf.yield %4
      } {
          %5 = arith.const {value = true} : core.i1
          scf.yield %5
      }
      func.return %3
  }
}
