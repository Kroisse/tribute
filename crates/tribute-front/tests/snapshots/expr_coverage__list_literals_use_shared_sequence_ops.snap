core.module @test {
  func.func @empty() -> tribute_rt.anyref attributes {tribute.calling_convention = 0} {
      %0 = list.empty {element_type = tribute_rt.anyref} : tribute_rt.anyref
      func.return %0
  }
  func.func @numbers() -> tribute_rt.anyref attributes {tribute.calling_convention = 0} {
      %0 = arith.const {value = 1} : core.i32
      %1 = arith.const {value = 2} : core.i32
      %2 = arith.const {value = 3} : core.i32
      %3 = list.empty {element_type = core.i32} : tribute_rt.anyref
      %4 = list.prepend %2, %3 {element_type = core.i32} : tribute_rt.anyref
      %5 = list.prepend %1, %4 {element_type = core.i32} : tribute_rt.anyref
      %6 = list.prepend %0, %5 {element_type = core.i32} : tribute_rt.anyref
      func.return %6
  }
}
