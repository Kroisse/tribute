core.module @test {
  func.func @set_and_get() -> core.i32 effects core.effect_row(core.ability_ref(core.i32) {name = @State}) {tail_var_id = 0} {
      %0 = arith.const {value = 42} : core.i32
      %1 = ability.call %0 {ability_ref = core.ability_ref() {name = @State}, op_name = @set} : tribute_rt.anyref
      %2 = core.unrealized_conversion_cast %1 : core.nil
      %3 = ability.call {ability_ref = core.ability_ref() {name = @State}, op_name = @get} : tribute_rt.anyref
      %4 = core.unrealized_conversion_cast %3 : core.i32
      func.return %4
  }
  func.func @main() -> core.nil {
      %0 = arith.const {value = unit} : core.nil
      func.return %0
  }
