core.module @test {
  !Point = adt.struct() {fields = [[@x, core.i32], [@y, core.i32]], name = @Point}

  core.module @Point {
    !Point_1 = adt.typeref() {name = @Point}

    func.func @"Point::x"(%0: !Point_1) -> core.i32 {
        %1 = adt.struct_get %0 {field = 0, type = !Point} : core.i32
        func.return %1
    }
    func.func @"Point::y"(%0: !Point_1) -> core.i32 {
        %1 = adt.struct_get %0 {field = 1, type = !Point} : core.i32
        func.return %1
    }
  }
  func.func @make_point() -> tribute_rt.anyref {
      %0 = arith.const {value = 10} : core.i32
      %1 = arith.const {value = 20} : core.i32
      %2 = adt.struct_new %0, %1 {type = !Point} : adt.typeref() {name = @Point}
      %3 = core.unrealized_conversion_cast %2 : tribute_rt.anyref
      func.return %3
  }
}
