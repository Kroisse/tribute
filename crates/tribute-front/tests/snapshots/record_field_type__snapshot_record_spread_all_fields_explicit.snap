core.module @test {
  !Point = adt.struct() {fields = [[@x, core.i32], [@y, core.i32]], name = @Point}

  core.module @Point {
    !Point_1 = adt.typeref() {name = @Point}

    func.func @"Point::x"(%0: !Point_1) -> core.i32 {
        %1 = adt.struct_get %0 {field = 0, type = !Point} : core.i32
        func.return %1
    }
    func.func @"Point::y"(%0: !Point_1) -> core.i32 {
        %1 = adt.struct_get %0 {field = 1, type = !Point} : core.i32
        func.return %1
    }
  }
  func.func @replace_all(%0: tribute_rt.anyref) -> tribute_rt.anyref {
      %1 = arith.const {value = 1} : core.i32
      %2 = arith.const {value = 2} : core.i32
      %3 = adt.struct_new %1, %2 {type = !Point} : adt.typeref() {name = @Point}
      func.return %3
  }
}
