core.module @test {
  !Config = adt.struct() {fields = [[@debug, core.i1], [@verbose, core.i1]], name = @Config}

  core.module @Config {
    !Config_1 = adt.typeref() {name = @Config}

    func.func @"Config::debug"(%0: !Config_1) -> core.i1 {
        %1 = adt.struct_get %0 {field = 0, type = !Config} : core.i1
        func.return %1
    }
    func.func @"Config::verbose"(%0: !Config_1) -> core.i1 {
        %1 = adt.struct_get %0 {field = 1, type = !Config} : core.i1
        func.return %1
    }
  }
  func.func @copy_config(%0: tribute_rt.anyref) -> tribute_rt.anyref {
      %1 = adt.struct_get %0 {field = 0, type = !Config} : tribute_rt.anyref
      %2 = adt.struct_get %0 {field = 1, type = !Config} : tribute_rt.anyref
      %3 = adt.struct_new %1, %2 {type = !Config} : adt.typeref() {name = @Config}
      %4 = core.unrealized_conversion_cast %3 : tribute_rt.anyref
      func.return %4
  }
}
