core.module @test {
  !Pair = adt.struct() {fields = [[@first, tribute_rt.anyref], [@second, tribute_rt.anyref]], name = @Pair}

  core.module @Pair {
    !Pair_1 = adt.typeref() {name = @Pair}

    func.func @"Pair::first"(%0: !Pair_1) -> tribute_rt.anyref {
        %1 = adt.struct_get %0 {field = 0, type = !Pair} : tribute_rt.anyref
        func.return %1
    }
    func.func @"Pair::second"(%0: !Pair_1) -> tribute_rt.anyref {
        %1 = adt.struct_get %0 {field = 1, type = !Pair} : tribute_rt.anyref
        func.return %1
    }
  }
  func.func @make_pair() -> tribute_rt.anyref {
      %0 = arith.const {value = 42} : core.i32
      %1 = arith.const {value = true} : core.i1
      %2 = adt.struct_new %0, %1 {type = !Pair} : adt.typeref() {name = @Pair}
      %3 = core.unrealized_conversion_cast %2 : tribute_rt.anyref
      func.return %3
  }
}
