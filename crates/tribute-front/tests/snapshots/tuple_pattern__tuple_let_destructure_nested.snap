core.module @test {
  func.func @test() -> core.i32 {
      %0 = arith.const {value = 1} : core.i32
      %1 = arith.const {value = 2} : core.i32
      %2 = arith.const {value = 3} : core.i32
      %3 = adt.struct_new %1, %2 {type = adt.struct() {fields = [[@0, core.i32], [@1, core.i32]], name = @__tuple_i32_i32}} : adt.typeref() {name = @__tuple_i32_i32}
