---
source: crates/tribute-front/tests/tuple_pattern.rs
expression: ir_text
---
core.module @test {
  !__tuple_i32_anyref = adt.struct() {fields = [[@0, core.i32], [@1, tribute_rt.anyref]], name = @__tuple_i32_anyref}
  !__tuple_i32_i32 = adt.struct() {fields = [[@0, core.i32], [@1, core.i32]], name = @__tuple_i32_i32}

  func.func @test() -> core.i32 attributes {tribute.calling_convention = 0} {
      %0 = arith.const {value = 1} : core.i32
      %1 = arith.const {value = 2} : core.i32
      %2 = arith.const {value = 3} : core.i32
      %3 = adt.struct_new %1, %2 {type = !__tuple_i32_i32} : adt.typeref() {name = @__tuple_i32_i32}
      %4 = adt.struct_new %0, %3 {type = !__tuple_i32_anyref} : adt.typeref() {name = @__tuple_i32_anyref}
      %5 = adt.struct_get %4 {field = 0, type = !__tuple_i32_anyref} : core.i32
      %6 = adt.struct_get %4 {field = 1, type = !__tuple_i32_anyref} : tribute_rt.anyref
      %7 = adt.struct_get %6 {field = 0, type = !__tuple_i32_i32} : core.i32
      %8 = adt.struct_get %6 {field = 1, type = !__tuple_i32_i32} : core.i32
      %9 = func.call %5, %7 {callee = @"Nat::+", tribute.calling_convention = 0} : core.i32
      %10 = func.call %9, %8 {callee = @"Nat::+", tribute.calling_convention = 0} : core.i32
      func.return %10
  }
}
