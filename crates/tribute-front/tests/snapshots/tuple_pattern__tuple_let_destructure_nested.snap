      %5 = adt.struct_get %4 {field = 0, type = adt.struct() {fields = [[@0, core.i32], [@1, tribute_rt.any]], name = @__tuple_i32_any}} : core.i32
      %6 = adt.struct_get %4 {field = 1, type = adt.struct() {fields = [[@0, core.i32], [@1, tribute_rt.any]], name = @__tuple_i32_any}} : tribute_rt.any
      %7 = adt.struct_get %6 {field = 0, type = adt.struct() {fields = [[@0, tribute_rt.any], [@1, tribute_rt.any]], name = @__tuple_any_any}} : tribute_rt.any
      %8 = adt.struct_get %6 {field = 1, type = adt.struct() {fields = [[@0, tribute_rt.any], [@1, tribute_rt.any]], name = @__tuple_any_any}} : tribute_rt.any
      %9 = arith.add %5, %7 : core.i32
      %10 = arith.add %9, %8 : core.i32
      func.return %10
